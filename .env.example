# Copy this file to .env and fill in credentials kept only on your machine.
# Explicit PowerShell environment variables override values in this file.

QDII_AKSHARE_PROXY_HOST=your-proxy-host
QDII_AKSHARE_PROXY_TOKEN=your-proxy-token
QDII_AKSHARE_PROXY_RETRY=30
# Comma-separated list of domains intercepted by akshare_proxy_patch.
QDII_AKSHARE_PROXY_HOOK_DOMAINS=push2his.eastmoney.com

# Optional server overrides:
# WEB_PORT=8010

# Refresh schedule overrides:
# QDII_QUOTE_REFRESH_MINUTES=5
# QDII_PREMARKET_REFRESH_MINUTES=5
# QDII_FRONTEND_AUTO_REFRESH_SECONDS=300
# Covers US daylight saving and standard time close anchors in Asia/Shanghai.
# QDII_US_CLOSE_REFRESH_TIMES=04:05,04:20,05:05,05:20
# QDII_LOG_FILE=data/qdii-monitor.log
